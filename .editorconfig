[*]
charset = utf-8
tab_width = 4
indent_size = 4
indent_style = space
end_of_line = lf
trim_trailing_whitespace = true
insert_final_newline = true
max_line_length = 100

[*.{ts,tsx}]
# https://youtrack.jetbrains.com/issue/WEB-21157
ij_typescript_use_double_quotes = false
ij_typescript_force_quote_style = true
