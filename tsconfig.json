{
    "extends": ["@vue/tsconfig/tsconfig.json"],

    "compilerOptions": {
        "allowSyntheticDefaultImports": true,
        "noFallthroughCasesInSwitch": true,
        "strictPropertyInitialization": false,

        "lib": ["esnext"],
        "types": ["node"]
    },

    "include": ["**/*"],
    "exclude": ["node_modules"]
}
